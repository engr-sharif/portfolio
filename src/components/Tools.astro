---
import Section from './Section.astro';
import { profile } from '../lib/profile';
const { tools } = profile;
---
{tools.length > 0 && (
  <Section id="tools" eyebrow="Engineer who builds" title="Tools I've built">
    <p style="color:var(--color-muted);max-width:52ch;margin:-2rem 0 2.5rem;font-size:var(--text-sm);">
      Small, targeted software that removes real friction from environmental fieldwork.
    </p>
    <div class="tools-grid" data-reveal-stagger>
      {tools.map((t) => (
        <article class="tool-card">
          <h3 class="tool-card__name">{t.name}</h3>
          <p class="tool-card__problem">{t.problem}</p>
          <p style="font-size:var(--text-sm);color:var(--color-paper-soft);">{t.description}</p>
          <div class="tool-card__tech">
            {t.tech.map((x) => <span>{x}</span>)}
          </div>
          {t.link && (
            <a href={t.link} class="link-underline" target="_blank" rel="noopener" style="font-size:var(--text-sm);color:var(--color-field-bright);">
              View ↗
            </a>
          )}
        </article>
      ))}
    </div>
  </Section>
)}
