---
import { Image } from 'astro:assets';
import { getCover } from '../lib/images';
import { withBase } from '../lib/path';
import { getFeatured } from '../lib/projects';
import StatusBadge from './atlas/StatusBadge.astro';

const featured = await getFeatured();
const total = String(featured.length).padStart(2, '0');
---
{featured.length > 0 && (
  <section class="showcase section" data-showcase aria-label="Flagship projects">
    <div class="u-container" style="margin-bottom:2.5rem;">
      <p class="section__eyebrow" data-reveal>Flagship work</p>
      <h2 data-reveal data-reveal-delay="0.05" style="font-size:var(--text-2xl);margin-top:1rem;max-width:20ch;">
        Scroll through the projects that define the work.
      </h2>
    </div>

    <div class="showcase__track">
      {featured.map((project, i) => {
        const cover = getCover(project.data.coverImage);
        return (
          <a class="showcase__panel" href={withBase(`projects/${project.id}/`)}>
            <span class="figure__corner figure__corner--bl" aria-hidden="true"></span>
            <span class="figure__corner figure__corner--br" aria-hidden="true"></span>
            {cover && (
              <Image
                src={cover}
                alt={`${project.data.title} — ${project.data.siteType}`}
                widths={[600, 1000, 1400]}
                sizes="80vw"
                loading="lazy"
              />
            )}
            <div class="showcase__overlay">
              <div class="showcase__top">
                <span class="showcase__index u-mono">{String(i + 1).padStart(2, '0')} / {total}</span>
                <StatusBadge status={project.data.status} />
              </div>
              <h3 class="showcase__name">{project.data.title}</h3>
              <p class="showcase__type">{project.data.siteType}</p>
              <ul class="showcase__tags">
                {project.data.techniques.slice(0, 3).map((t) => <li class="chip">{t}</li>)}
              </ul>
            </div>
          </a>
        );
      })}
    </div>
  </section>
)}

<script>
  import '../lib/showcase';
</script>
