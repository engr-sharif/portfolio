---
import { Image } from 'astro:assets';
import Section from './Section.astro';
import { allGalleryImages, getGalleryImage } from '../lib/images';
import media from '../content/settings/media.json';
import galleryData from '../content/settings/gallery.json';

/**
 * Field gallery. Primary source is the CMS-managed list (src/content/settings/
 * gallery.json → editable at /admin → Field Gallery), which carries alt text
 * for accessibility. If that list is empty we fall back to auto-globbing every
 * image in src/assets/gallery/ (the "drop a file in the folder" workflow still
 * works). Either way images go through Astro's <Image> optimizer.
 *
 * Video: GitHub is a poor video host (100 MB/file limit, no CDN). Videos are
 * external embeds (YouTube/Vimeo) configured in media.json.
 */
const curated = (galleryData.photos ?? [])
  .map((p) => ({ img: getGalleryImage(p.image), alt: p.alt || 'Field photo', caption: p.caption }))
  .filter((p) => p.img);

const images =
  curated.length > 0
    ? curated
    : allGalleryImages.map(({ name, img }) => ({ img, alt: `Field photo: ${name}`, caption: '' }));

const videos = (media.videos ?? []).filter((v) => v.id || v.url);

function videoHref(v: { provider: string; id: string; url: string }) {
  if (v.url) return v.url;
  if (v.provider === 'youtube') return `https://www.youtube.com/watch?v=${v.id}`;
  if (v.provider === 'vimeo') return `https://vimeo.com/${v.id}`;
  return '#';
}
---
<Section id="field" eyebrow="From the field" title="Field photography">
  <p style="color:var(--color-muted);max-width:52ch;margin:-2rem 0 2.5rem;font-size:var(--text-sm);">
    Sampling, scanning, and monitoring on site. {media.galleryNote}
  </p>

  {images.length > 0 ? (
    <div class="gallery">
      {images.map(({ img, alt }) => (
        <button class="gallery__item" data-lightbox aria-label={`Open photo: ${alt}`}>
          <Image src={img!} alt={alt} widths={[300, 600, 900]} sizes="(max-width: 640px) 45vw, 18rem" loading="lazy" />
        </button>
      ))}
    </div>
  ) : (
    <p style="color:var(--color-muted);">No field photos yet — add them in <code>/admin → Field Gallery</code>.</p>
  )}

  {videos.length > 0 && (
    <div class="gallery-video">
      {videos.map((v) => {
        const poster = v.poster ? getGalleryImage(v.poster) : undefined;
        return (
          <a class="gallery-video__card" href={videoHref(v)} target="_blank" rel="noopener" aria-label={`Watch: ${v.title}`}>
            {poster && <Image src={poster} alt={v.title} widths={[400, 800]} sizes="20rem" loading="lazy" />}
            <span class="gallery-video__play">
              <span aria-hidden="true">▶</span>
              {v.title}
            </span>
          </a>
        );
      })}
    </div>
  )}
</Section>

<script>
  import '../lib/lightbox';
</script>
