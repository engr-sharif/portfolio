---
import Section from './Section.astro';
import { profile } from '../lib/profile';
const { credentials, certifications } = profile;
---
{(credentials.length > 0 || certifications.length > 0) && (
  <Section id="credentials" eyebrow="Credentials" title="Licensure & certifications">
    <div class="cred-grid">
      {credentials.length > 0 && (
        <div data-reveal>
          <p class="skill-group__name">Licensure</p>
          <div class="cred-list">
            {credentials.map((c) => (
              <div class="cred-item">
                <div>
                  <div class="cred-item__label">{c.label}</div>
                  <div class="cred-item__sub">{c.issuer}</div>
                </div>
                <div class={`cred-item__status${/progress|anticipat/i.test(c.status) ? ' cred-item__status--progress' : ''}`}>
                  {c.status}<br /><span class="cred-item__sub">{c.date}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
      {certifications.length > 0 && (
        <div data-reveal data-reveal-delay="0.08">
          <p class="skill-group__name">Field certifications</p>
          <div class="cred-list">
            {certifications.map((c) => (
              <div class="cred-item">
                <div>
                  <div class="cred-item__label">{c.label}</div>
                  <div class="cred-item__sub">{c.issuer}</div>
                </div>
                <div class="cred-item__status">
                  {c.date}{c.expires && <><br /><span class="cred-item__sub">exp. {c.expires}</span></>}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </Section>
)}
