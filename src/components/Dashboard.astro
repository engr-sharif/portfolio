---
import Section from './Section.astro';
import ProjectCard from './ProjectCard.astro';
import { withBase } from '../lib/path';
import { getProjects } from '../lib/projects';

// Homepage shows a curated subset; the full, filterable list lives at /projects.
const all = await getProjects();
const projects = all.slice(0, 6);
---
<Section id="work" eyebrow="Project dashboard" title="Selected environmental projects">
  <p style="color:var(--color-muted);max-width:52ch;margin:-2rem 0 2.5rem;font-size:var(--text-sm);">
    A live record of characterization, remediation, and quality-assurance work.
    All entries use public, high-level descriptions.
  </p>

  <div class="project-grid" data-reveal-stagger>
    {projects.map((project) => <ProjectCard project={project} />)}
  </div>

  {all.length > projects.length && (
    <p style="margin-top:2.5rem;">
      <a href={withBase('projects/')} class="btn btn--ghost" data-magnetic="0.3">
        All {all.length} projects →
      </a>
    </p>
  )}
</Section>
