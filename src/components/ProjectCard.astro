---
import { Image } from 'astro:assets';
import { getCover } from '../lib/images';
import { withBase } from '../lib/path';
import { statusLabel, dateRange, type Project } from '../lib/projects';

export interface Props {
  project: Project;
}
const { project } = Astro.props;
const { data } = project;
const cover = getCover(data.coverImage);
const href = withBase(`projects/${project.id}/`);
---
<article
  class="card"
  data-status={data.status}
  data-card
  data-techniques={data.techniques.join(',')}
>
  <a href={href} class="card__link" aria-label={`View project: ${data.title}`}>
    <div class="card__media">
      {cover ? (
        <Image
          src={cover}
          alt={data.coverAlt || `${data.title} — ${data.siteType}`}
          widths={[400, 800, 1200]}
          sizes="(max-width: 640px) 90vw, 30vw"
          loading="lazy"
          class="card__img"
          style={`view-transition-name: cover-${project.id}`}
        />
      ) : (
        <div class="card__img card__img--placeholder" aria-hidden="true"></div>
      )}
      <span class={`card__status card__status--${data.status}`}>{statusLabel[data.status]}</span>
    </div>

    <div class="card__body">
      <h3 class="card__title">{data.title}</h3>
      <p class="card__meta">{data.client} · {dateRange(data.startDate, data.endDate)}</p>
      <p class="card__summary">{data.summary}</p>
      <ul class="card__tags">
        {data.techniques.slice(0, 4).map((t) => <li>{t}</li>)}
      </ul>
    </div>
  </a>
</article>

<style>
  .card {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: var(--color-ink-soft);
    border: 1px solid color-mix(in srgb, var(--color-paper) 8%, transparent);
    transition: border-color 0.4s var(--ease-out-expo);
  }
  .card:hover { border-color: color-mix(in srgb, var(--color-field-bright) 50%, transparent); }
  .card__link { display: block; height: 100%; }
  .card__media { position: relative; aspect-ratio: 3 / 2; overflow: hidden; }
  .card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease-out-expo);
  }
  .card:hover .card__img { transform: scale(1.05); }
  .card__img--placeholder {
    background: linear-gradient(135deg, var(--color-field-dim), var(--color-ink-soft));
  }
  .card__status {
    position: absolute;
    top: 0.9rem;
    left: 0.9rem;
    padding: 0.3em 0.8em;
    border-radius: 999px;
    font-size: var(--text-xs);
    font-weight: 500;
    backdrop-filter: blur(8px);
    background: color-mix(in srgb, var(--color-ink) 55%, transparent);
  }
  .card__status--active { color: var(--color-field-bright); }
  .card__status--complete { color: var(--color-paper-soft); }
  .card__status--proposed { color: #d7c47a; }
  .card__body { padding: 1.4rem 1.4rem 1.6rem; }
  .card__title { font-size: var(--text-lg); }
  .card__meta { color: var(--color-muted); font-size: var(--text-sm); margin-top: 0.35rem; }
  .card__summary {
    margin-top: 0.9rem;
    color: var(--color-paper-soft);
    font-size: var(--text-sm);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.1rem;
    padding: 0;
  }
  .card__tags li {
    font-size: var(--text-xs);
    padding: 0.3em 0.7em;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-paper) 14%, transparent);
    color: var(--color-paper-soft);
  }
</style>
