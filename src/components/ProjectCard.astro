---
import { Image } from 'astro:assets';
import { getCover } from '../lib/images';
import { withBase } from '../lib/path';
import { dateRange, type Project } from '../lib/projects';
import StatusBadge from './atlas/StatusBadge.astro';

export interface Props {
  project: Project;
}
const { project } = Astro.props;
const { data } = project;
const cover = getCover(data.coverImage);
const href = withBase(`projects/${project.id}/`);
---
<article
  class="card"
  data-status={data.status}
  data-card
  data-techniques={data.techniques.join(',')}
>
  <a href={href} class="card__link" aria-label={`View project: ${data.title}`}>
    <div class="card__media">
      {cover ? (
        <Image
          src={cover}
          alt={data.coverAlt || `${data.title} — ${data.siteType}`}
          widths={[400, 800, 1200]}
          sizes="(max-width: 640px) 90vw, 30vw"
          loading="lazy"
          class="card__img"
          style={`view-transition-name: cover-${project.id}`}
        />
      ) : (
        <div class="card__img card__img--placeholder" aria-hidden="true"></div>
      )}
      <span class="card__corner card__corner--tl" aria-hidden="true"></span>
      <span class="card__corner card__corner--br" aria-hidden="true"></span>
      <StatusBadge status={data.status} class="card__status" />
    </div>

    <div class="card__body">
      <h3 class="card__title">{data.title}</h3>
      <p class="card__meta u-mono">{data.client} · {dateRange(data.startDate, data.endDate)}</p>
      <p class="card__summary">{data.summary}</p>
      <ul class="card__tags">
        {data.techniques.slice(0, 4).map((t) => <li class="chip">{t}</li>)}
      </ul>
    </div>
  </a>
</article>

<style>
  .card {
    position: relative;
    border-radius: 6px;
    overflow: hidden;
    background: var(--color-ink-1);
    border: 1px solid var(--color-line);
    transition: border-color var(--dur-base) var(--ease-out-expo), transform var(--dur-base) var(--ease-out-expo);
  }
  .card:hover {
    border-color: color-mix(in srgb, var(--color-field-bright) 55%, transparent);
    transform: translateY(-4px);
  }
  .card__link { display: block; height: 100%; }
  .card__media { position: relative; aspect-ratio: 3 / 2; overflow: hidden; }
  .card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease-out-expo);
  }
  .card:hover .card__img { transform: scale(1.05); }
  .card__img--placeholder {
    background: linear-gradient(135deg, var(--color-field-dim), var(--color-ink-1));
  }
  /* registration marks on the media (atlas motif) */
  .card__corner {
    position: absolute;
    width: 9px; height: 9px;
    border: 1px solid color-mix(in srgb, var(--color-field-bright) 70%, transparent);
    z-index: 2; pointer-events: none;
    opacity: 0; transition: opacity var(--dur-fast) var(--ease-out-expo);
  }
  .card:hover .card__corner { opacity: 1; }
  .card__corner--tl { top: 8px; left: 8px; border-right: 0; border-bottom: 0; }
  .card__corner--br { bottom: 8px; right: 8px; border-left: 0; border-top: 0; }
  .card__status {
    position: absolute;
    top: 0.8rem; right: 0.8rem;
    backdrop-filter: blur(8px);
    background: color-mix(in srgb, var(--color-ink) 55%, transparent);
  }
  .card__body { padding: 1.4rem 1.4rem 1.6rem; }
  .card__title { font-size: var(--text-lg); }
  .card__meta { color: var(--color-muted); font-size: var(--text-xs); margin-top: 0.45rem; }
  .card__summary {
    margin-top: 0.9rem;
    color: var(--color-paper-soft);
    font-size: var(--text-sm);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.1rem;
    padding: 0;
  }
</style>
