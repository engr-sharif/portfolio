---
import Section from './Section.astro';
import { site } from '../lib/site';
import { repos, langColor, relativeTime } from '../lib/code';
---
{repos.length > 0 && (
  <Section id="code" eyebrow="Open source" title="Code & repositories">
    <p style="color:var(--color-muted);max-width:54ch;margin:-2rem 0 2.5rem;font-size:var(--text-sm);">
      Public repositories — mapping, data, and field tools I've built. Pulled from
      <a href={site.github} class="link-underline" target="_blank" rel="noopener" style="color:var(--color-field-bright);"> GitHub</a>.
    </p>

    <div class="repo-grid" data-reveal-stagger>
      {repos.map((r) => (
        <a class="repo-card" href={r.url} target="_blank" rel="noopener" aria-label={`View ${r.name} on GitHub`}>
          <div class="repo-card__head">
            <svg class="repo-card__icon" viewBox="0 0 16 16" width="18" height="18" aria-hidden="true" fill="currentColor">
              <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.25.25 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z" />
            </svg>
            <span class="repo-card__name">{r.name}</span>
          </div>
          {r.description && <p class="repo-card__desc">{r.description}</p>}
          <div class="repo-card__meta">
            {r.language && (
              <span class="repo-card__lang">
                <span class="repo-card__dot" style={`background:${langColor(r.language)}`}></span>
                {r.language}
              </span>
            )}
            {r.stars > 0 && <span>★ {r.stars}</span>}
            {r.pushedAt && <span>{relativeTime(r.pushedAt)}</span>}
          </div>
        </a>
      ))}
    </div>

    <p style="margin-top:2rem;">
      <a href={site.github} class="link-underline" target="_blank" rel="noopener" style="color:var(--color-muted);font-size:var(--text-sm);">
        All repositories on GitHub →
      </a>
    </p>
  </Section>
)}
