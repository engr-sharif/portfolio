---
import { site } from '../lib/site';
import { withBase } from '../lib/path';
import HeroScene from './three/HeroScene.tsx';
---
<section class="hero" aria-label="Introduction">
  <!-- WebGL backdrop (the one splurge). client:visible keeps JS off the
       critical path; the scene self-pauses under reduced-motion / offscreen. -->
  <HeroScene client:visible />

  <div class="hero__inner u-container">
    <p class="hero__eyebrow" data-hero-fade>{site.credential}</p>
    <h1 class="hero__title" data-hero-title>
      Environmental<br />characterization<br />&amp; remediation.
    </h1>
    <p class="hero__sub" data-hero-fade>{site.role}</p>
    <div class="hero__cta" data-hero-fade>
      <a href={withBase('#work')} class="btn" data-magnetic="0.4">View the work</a>
      <a href={withBase(site.resume)} class="btn btn--ghost" data-magnetic="0.4" download>Download résumé</a>
    </div>
  </div>

  <div class="hero__scroll" data-hero-fade aria-hidden="true">
    <span>Scroll</span>
    <span class="hero__scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero-canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-canvas :global(canvas) {
    width: 100% !important;
    height: 100% !important;
  }
  .hero__inner {
    position: relative;
    z-index: 2;
    padding-top: 6rem;
  }
  .hero__eyebrow {
    color: var(--color-field-bright);
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-size: var(--text-sm);
    margin-bottom: 1.4rem;
    opacity: 0;
  }
  .hero__title {
    font-size: var(--text-hero);
    opacity: 0; /* revealed by SplitText (or instantly under reduced-motion) */
    max-width: 16ch;
  }
  .hero__sub {
    margin-top: 1.8rem;
    max-width: 42ch;
    color: var(--color-paper-soft);
    font-size: var(--text-lg);
    opacity: 0;
  }
  .hero__cta {
    margin-top: 2.6rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    opacity: 0;
  }
  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-muted);
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0;
  }
  .hero__scroll-line {
    width: 1px;
    height: 3rem;
    background: linear-gradient(var(--color-field-bright), transparent);
    animation: scrollPulse 2.2s var(--ease-in-out-quart) infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { transform: scaleY(0.4); transform-origin: top; opacity: 0.4; }
    50% { transform: scaleY(1); transform-origin: top; opacity: 1; }
  }
  /* SplitText mask wrappers */
  .hero__title :global(.split-line-inner) { display: block; }
</style>

<script>
  import '../lib/hero';
</script>
