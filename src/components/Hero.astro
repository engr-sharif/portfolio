---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { site } from '../lib/site';
import { withBase } from '../lib/path';
import HeroScene from './three/HeroScene.tsx';

// Optional hero background image. Resolution order:
//  1. site.heroBackground (a filename set in /admin → Site Settings), matched
//     case-insensitively by basename;
//  2. otherwise the first non-placeholder image in src/assets/hero/;
//  3. otherwise the first image found (placeholder).
// Drop an image into src/assets/hero/ (via /admin or directly) → it's the
// backdrop. The WebGL particles drift on top for motion.
const heroModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/hero/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG,WEBP,AVIF}',
  { eager: true },
);
const heroEntries = Object.entries(heroModules);
const base = (p: string) => (p.split(/[\\/]/).pop() ?? '').toLowerCase();
const wanted = (site.heroBackground ?? '').trim();
const picked =
  (wanted && heroEntries.find(([p]) => base(p) === base(wanted))) ||
  heroEntries.find(([p]) => !base(p).includes('placeholder')) ||
  heroEntries[0];
const heroBg = picked?.[1].default;
---
<section class:list={['hero', { 'hero--has-bg': heroBg }]} aria-label="Introduction">
  {heroBg && (
    <Image
      src={heroBg}
      alt=""
      aria-hidden="true"
      class="hero__bg"
      widths={[768, 1280, 1920, 2560]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
  )}
  <div class="hero__scrim" aria-hidden="true"></div>

  <!-- WebGL particle field — drifts on top of the background image (or stands
       alone if there's no image). Freezes to a still pattern under reduced
       motion; never just a black panel. -->
  <HeroScene client:visible />

  <div class="hero__inner u-container">
    <p class="hero__eyebrow" data-hero-fade>{site.credential} · {site.location.split(',')[0]}</p>
    <h1 class="hero__title" data-hero-title>{site.heroTitle || site.name}</h1>
    <p class="hero__sub" data-hero-fade>{site.role}</p>
    <div class="hero__cta" data-hero-fade>
      <a href={withBase('#work')} class="btn" data-magnetic="0.4">View the work</a>
      <a href={withBase(site.resume)} class="btn btn--ghost" data-magnetic="0.4" download>Download résumé</a>
    </div>
  </div>

  <div class="hero__scroll" data-hero-fade aria-hidden="true">
    <span>Scroll</span>
    <span class="hero__scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    /* Backdrop behind the particle canvas (and the visible field between
       points): a dark-green wash, not pure black. */
    background:
      radial-gradient(130% 90% at 78% -10%, color-mix(in srgb, var(--color-field-dim) 80%, transparent), transparent 62%),
      radial-gradient(100% 80% at 12% 112%, color-mix(in srgb, var(--color-field) 38%, transparent), transparent 58%),
      var(--color-ink);
  }
  .hero-canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  /* Background image (when present) sits beneath everything. */
  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }
  /* Legibility scrim — darkens the center/bottom so the name always reads,
     and blends the image into the dark page below. */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(80% 60% at 50% 58%, color-mix(in srgb, var(--color-ink) 55%, transparent), transparent 70%),
      linear-gradient(to bottom, transparent 40%, color-mix(in srgb, var(--color-ink) 85%, transparent) 100%);
  }
  /* When an image is present, the canvas blends as a subtle moving accent
     rather than the main event. */
  .hero--has-bg .hero-canvas { z-index: 1; opacity: 0.4; mix-blend-mode: screen; }
  .hero-canvas :global(canvas) {
    width: 100% !important;
    height: 100% !important;
  }
  /* The content column owns the vertical centering and full width — no flex on
     .hero (which let the title shrink into a narrow column on mobile). */
  .hero__inner {
    position: relative;
    z-index: 2;
    width: min(100% - 2.5rem, 80rem);
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 6rem;
    padding-bottom: 5rem;
  }
  .hero__eyebrow {
    color: var(--color-field-bright);
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-size: var(--text-sm);
    margin-bottom: 1.4rem;
    opacity: 0;
  }
  .hero__title {
    font-size: var(--text-hero);
    opacity: 0; /* revealed by SplitText (or instantly under reduced-motion) */
    max-width: 15ch;
    /* Last-resort break only (no hyphens) so a long word never overflows on
       very narrow phones — it wraps cleanly instead. */
    overflow-wrap: break-word;
    text-wrap: balance;
  }
  @media (max-width: 520px) {
    .hero__title { max-width: 100%; }
  }
  .hero__sub {
    margin-top: 1.8rem;
    max-width: 42ch;
    color: var(--color-paper-soft);
    font-size: var(--text-lg);
    opacity: 0;
  }
  .hero__cta {
    margin-top: 2.6rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    opacity: 0;
  }
  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-muted);
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0;
  }
  .hero__scroll-line {
    width: 1px;
    height: 3rem;
    background: linear-gradient(var(--color-field-bright), transparent);
    animation: scrollPulse 2.2s var(--ease-in-out-quart) infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { transform: scaleY(0.4); transform-origin: top; opacity: 0.4; }
    50% { transform: scaleY(1); transform-origin: top; opacity: 1; }
  }
  /* SplitText mask wrappers */
  .hero__title :global(.split-line-inner) { display: block; }
</style>

<script>
  import '../lib/hero';
</script>
