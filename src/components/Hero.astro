---
import { site } from '../lib/site';
import { withBase } from '../lib/path';
import HeroScene from './three/HeroScene.tsx';
---
<section class="hero" aria-label="Introduction">
  <!-- WebGL backdrop (the signature animation). Loaded on every device so the
       hero is never a black panel; the scene scales density down on phones and
       freezes to a still pattern (no animation) under reduced-motion. -->
  <HeroScene client:visible />

  <div class="hero__inner u-container">
    <p class="hero__eyebrow" data-hero-fade>{site.credential} · {site.location.split(',')[0]}</p>
    <h1 class="hero__title" data-hero-title>{site.heroTitle || site.name}</h1>
    <p class="hero__sub" data-hero-fade>{site.role}</p>
    <div class="hero__cta" data-hero-fade>
      <a href={withBase('#work')} class="btn" data-magnetic="0.4">View the work</a>
      <a href={withBase(site.resume)} class="btn btn--ghost" data-magnetic="0.4" download>Download résumé</a>
    </div>
  </div>

  <div class="hero__scroll" data-hero-fade aria-hidden="true">
    <span>Scroll</span>
    <span class="hero__scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    /* Backdrop behind the particle canvas (and the visible field between
       points): a dark-green wash, not pure black. */
    background:
      radial-gradient(130% 90% at 78% -10%, color-mix(in srgb, var(--color-field-dim) 80%, transparent), transparent 62%),
      radial-gradient(100% 80% at 12% 112%, color-mix(in srgb, var(--color-field) 38%, transparent), transparent 58%),
      var(--color-ink);
  }
  .hero-canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-canvas :global(canvas) {
    width: 100% !important;
    height: 100% !important;
  }
  /* The content column owns the vertical centering and full width — no flex on
     .hero (which let the title shrink into a narrow column on mobile). */
  .hero__inner {
    position: relative;
    z-index: 2;
    width: min(100% - 2.5rem, 80rem);
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 6rem;
    padding-bottom: 5rem;
  }
  .hero__eyebrow {
    color: var(--color-field-bright);
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-size: var(--text-sm);
    margin-bottom: 1.4rem;
    opacity: 0;
  }
  .hero__title {
    font-size: var(--text-hero);
    opacity: 0; /* revealed by SplitText (or instantly under reduced-motion) */
    max-width: 15ch;
    /* Last-resort break only (no hyphens) so a long word never overflows on
       very narrow phones — it wraps cleanly instead. */
    overflow-wrap: break-word;
    text-wrap: balance;
  }
  @media (max-width: 520px) {
    .hero__title { max-width: 100%; }
  }
  .hero__sub {
    margin-top: 1.8rem;
    max-width: 42ch;
    color: var(--color-paper-soft);
    font-size: var(--text-lg);
    opacity: 0;
  }
  .hero__cta {
    margin-top: 2.6rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    opacity: 0;
  }
  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-muted);
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0;
  }
  .hero__scroll-line {
    width: 1px;
    height: 3rem;
    background: linear-gradient(var(--color-field-bright), transparent);
    animation: scrollPulse 2.2s var(--ease-in-out-quart) infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { transform: scaleY(0.4); transform-origin: top; opacity: 0.4; }
    50% { transform: scaleY(1); transform-origin: top; opacity: 1; }
  }
  /* SplitText mask wrappers */
  .hero__title :global(.split-line-inner) { display: block; }
</style>

<script>
  import '../lib/hero';
</script>
