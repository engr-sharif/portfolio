---
import { site } from '../lib/site';
import { withBase } from '../lib/path';
import { getProjects } from '../lib/projects';
import { getTools } from '../lib/tools';
import HeroScene from './three/HeroScene.tsx';

// A rotating "instrument readout" of live facts under the name — turns the
// subhead area into data, not a slogan. Derived from real content + settings.
const projects = await getProjects();
const tools = await getTools();
const active = projects.filter((p) => p.data.status === 'active');
const statusLines = [
  active[0] ? `${active[0].data.title} — active` : null,
  'EIT → PE anticipated 2027',
  tools.length > 0 ? `${tools.length} field tools shipped` : null,
  `${projects.length} projects documented`,
].filter(Boolean) as string[];
---
<section class="hero" aria-label="Introduction" data-hero>
  <!-- WebGL particle field — the full hero backdrop. Drifts on every device
       (density scales down on phones), freezes to a still pattern under
       reduced motion. -->
  <div class="hero__canvas-wrap" data-hero-parallax="bg">
    <HeroScene client:visible />
  </div>

  <div class="hero__inner u-container" data-hero-parallax="content">
    <p class="hero__eyebrow" data-hero-fade>{site.credential} · {site.location.split(',')[0]}</p>
    <h1 class="hero__title" data-hero-title>{site.heroTitle || site.name}</h1>
    <p class="hero__sub" data-hero-fade>{site.role}</p>

    {statusLines.length > 0 && (
      <div class="hero__status u-mono" data-hero-fade data-status-rotator aria-live="off">
        <span class="hero__status-key" aria-hidden="true">NOW</span>
        <span class="hero__status-line" data-status-lines={JSON.stringify(statusLines)}>{statusLines[0]}</span>
      </div>
    )}

    <div class="hero__cta" data-hero-fade>
      <a href={withBase(site.resume)} class="btn" data-magnetic="0.4" download>Download résumé</a>
      <a href={withBase('#work')} class="btn btn--ghost" data-magnetic="0.4">View the work</a>
    </div>

    <p class="hero__avail u-mono" data-hero-fade>
      <span class="hero__avail-dot" aria-hidden="true"></span>Open to remediation roles across California
    </p>
  </div>

  <div class="hero__scroll" data-hero-fade aria-hidden="true">
    <span>Scroll</span>
    <span class="hero__scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    /* Backdrop behind the particle canvas (and the visible field between
       points): a dark-green wash, not pure black. */
    background:
      radial-gradient(130% 90% at 78% -10%, color-mix(in srgb, var(--color-field-dim) 80%, transparent), transparent 62%),
      radial-gradient(100% 80% at 12% 112%, color-mix(in srgb, var(--color-field) 38%, transparent), transparent 58%),
      var(--color-ink);
  }
  .hero__canvas-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
    will-change: transform;
  }
  .hero-canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-canvas :global(canvas) {
    width: 100% !important;
    height: 100% !important;
  }
  /* The content column owns the vertical centering and full width — no flex on
     .hero (which let the title shrink into a narrow column on mobile). */
  .hero__inner {
    position: relative;
    z-index: 2;
    width: min(100% - 2.5rem, 80rem);
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 6rem;
    padding-bottom: 5rem;
  }
  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.8em;
    color: var(--color-field-bright);
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-size: var(--text-sm);
    margin-bottom: 1.4rem;
    opacity: 0;
  }
  .hero__eyebrow::before {
    content: '';
    width: 2.2rem;
    height: 1px;
    background: var(--color-field-bright);
    opacity: 0.7;
  }
  .hero__title {
    font-size: var(--text-hero);
    opacity: 0; /* revealed by SplitText (or instantly under reduced-motion) */
    max-width: 15ch;
    /* Last-resort break only (no hyphens) so a long word never overflows on
       very narrow phones — it wraps cleanly instead. */
    overflow-wrap: break-word;
    text-wrap: balance;
  }
  @media (max-width: 520px) {
    .hero__title { max-width: 100%; }
  }
  .hero__sub {
    margin-top: 1.8rem;
    max-width: 42ch;
    color: var(--color-paper-soft);
    font-size: var(--text-lg);
    opacity: 0;
  }
  .hero__status {
    margin-top: 1.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    font-size: var(--text-sm);
    opacity: 0;
  }
  .hero__status-key {
    color: var(--color-hazard);
    font-size: var(--text-xs);
    letter-spacing: 0.16em;
    border: 1px solid color-mix(in srgb, var(--color-hazard) 45%, transparent);
    border-radius: 4px;
    padding: 0.2em 0.55em;
  }
  .hero__status-line {
    color: var(--color-paper-soft);
    transition: opacity 0.4s var(--ease-out-expo), transform 0.4s var(--ease-out-expo);
  }
  .hero__status-line.is-swapping { opacity: 0; transform: translateY(-0.4em); }
  .hero__cta {
    margin-top: 2.6rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    opacity: 0;
  }
  .hero__avail {
    margin-top: 1.3rem;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--color-field-bright);
    font-size: var(--text-sm);
    opacity: 0;
  }
  .hero__avail-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: currentColor; flex: none;
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-field-bright) 60%, transparent);
    animation: avail-pulse 2.4s var(--ease-in-out-quart, ease-in-out) infinite;
  }
  @keyframes avail-pulse {
    0%, 100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-field-bright) 55%, transparent); }
    50% { box-shadow: 0 0 0 5px transparent; }
  }
  @media (prefers-reduced-motion: reduce) { .hero__avail-dot { animation: none; } }
  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-muted);
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0;
  }
  .hero__scroll-line {
    width: 1px;
    height: 3rem;
    background: linear-gradient(var(--color-field-bright), transparent);
    animation: scrollPulse 2.2s var(--ease-in-out-quart) infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { transform: scaleY(0.4); transform-origin: top; opacity: 0.4; }
    50% { transform: scaleY(1); transform-origin: top; opacity: 1; }
  }
  /* SplitText mask wrappers */
  .hero__title :global(.split-line-inner) { display: block; }
</style>

<script>
  import '../lib/hero';
  import '../lib/hero-parallax';
</script>
