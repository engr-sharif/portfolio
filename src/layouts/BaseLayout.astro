---
import '../styles/global.css';
// Self-hosted variable fonts (no render-blocking Google CDN, no GDPR concern).
import '@fontsource-variable/inter';
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/jetbrains-mono';
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CommandPalette from '../components/CommandPalette.tsx';
import { withBase } from '../lib/path';
import { site } from '../lib/site';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  showChrome?: boolean;
  ogType?: string;
}

// Site-wide SEO/share defaults are editable in the Studio (Site Settings);
// fall back to the baked-in copy when those fields are left blank. Per-page
// props still override everything.
const {
  title = site.seoTitle?.trim() || `${site.name} — ${site.credential}`,
  description = site.seoDescription?.trim() || site.bio,
  image = site.ogImage?.trim() || '/og-image.png',
  showChrome = true,
  ogType = 'website',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
// Per-page cover images arrive as already-absolute URLs; site defaults are
// base-relative (e.g. /og-image.png) and need the base + origin prepended.
const ogImage = /^https?:\/\//.test(image) ? image : new URL(withBase(image), Astro.site).href;

// Site-wide Person structured data (EEAT / rich-result signal). Built once on
// the homepage-level layout; absolute URLs so it's valid under /portfolio/.
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  jobTitle: site.credential,
  worksFor: { '@type': 'Organization', name: site.employer || '' },
  address: { '@type': 'PostalAddress', addressLocality: site.location },
  url: Astro.site?.href,
  email: `mailto:${site.email}`,
  sameAs: [site.linkedin, site.github].filter(Boolean),
  knowsAbout: [
    'Structural engineering',
    'Structural analysis',
    'Seismic design',
    'Dam & levee safety',
    'Water infrastructure',
  ],
};

// Optional privacy-friendly analytics: set site.analytics to your GoatCounter
// subdomain (e.g. "engr-sharif") to enable. Empty → no script, no tracking.
const goatcounter = (site as { analytics?: string }).analytics?.trim();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Mark JS as available before first paint so reveal elements can start
         hidden without a flash (html.js gate in global.css). -->
    <script is:inline>document.documentElement.classList.add('js');</script>
    <link rel="icon" href={withBase('favicon.svg')} type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content={site.name} />
    <meta name="theme-color" content="#0c0e0d" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- RSS discovery -->
    <link rel="alternate" type="application/rss+xml" title={`${site.shortName} — Writing`} href={new URL(withBase('rss.xml'), Astro.site).href} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(personLd)} is:inline />

    <ClientRouter />
    <noscript><style>#intro { display: none !important; }</style></noscript>
    {goatcounter && (
      <script
        is:inline
        data-goatcounter={`https://${goatcounter}.goatcounter.com/count`}
        async
        src="//gc.zgo.at/count.js"></script>
    )}
  </head>
  <body>
    {showChrome && (
      <div id="intro" aria-hidden="true">
        <div class="intro__mask"><span class="intro__label">{site.name}</span></div>
        <div class="intro__bar"></div>
      </div>
    )}
    <a href="#main" class="sr-skip">Skip to content</a>
    <div class="u-grain" aria-hidden="true"></div>
    {showChrome && <Nav />}
    <main id="main">
      <slot />
    </main>
    {showChrome && <Footer />}
    {showChrome && (
      <CommandPalette
        client:idle
        base={import.meta.env.BASE_URL}
        nav={[
          { label: 'Projects', href: withBase('projects/'), hint: 'Project dashboard' },
          { label: 'Tools', href: withBase('tools/'), hint: 'Software I’ve built' },
          { label: 'Writing', href: withBase('blog/'), hint: 'Field notes & technical posts' },
          { label: 'About', href: withBase('about/'), hint: 'Bio, skills, credentials' },
          { label: 'Contact', href: withBase('#contact'), hint: 'Get in touch' },
        ]}
      />
    )}

    <script>
      // Boot global motion (Lenis + GSAP + cursor + reveals). The module
      // self-registers astro:page-load, but we also call it once for the
      // very first load in case the event already fired.
      import { bootMotion } from '../lib/motion';
      import '../lib/intro';
      bootMotion();
    </script>
    {goatcounter && (
      <script is:inline>
        // Count client-side (View Transition) navigations too.
        document.addEventListener('astro:after-swap', () => {
          // @ts-ignore
          window.goatcounter?.count?.({ path: location.pathname });
        });
      </script>
    )}
  </body>
</html>
