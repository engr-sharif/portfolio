---
import { render } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/blog/TableOfContents.astro';
import StatusBadge from '../../components/atlas/StatusBadge.astro';
import Breadcrumb from '../../components/atlas/Breadcrumb.astro';
import LiveRegulatoryStatus from '../../components/LiveRegulatoryStatus.tsx';
import { getCover, getGalleryImage } from '../../lib/images';
import { getCaption } from '../../lib/captions';
import { withBase } from '../../lib/path';
import { getProjects, dateRange } from '../../lib/projects';

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;
const { Content, headings } = await render(project);
const group = `project-${project.id}`;

const cover = getCover(data.coverImage);
const coverFull = cover ? (await getImage({ src: cover, width: 2400, format: 'webp' })).src : undefined;
const coverCaption = getCaption(data.coverImage);
// Per-project social share image (cover cropped to the OG ratio, absolute URL).
const ogImage = cover
  ? new URL((await getImage({ src: cover, width: 1200, height: 630, fit: 'cover', format: 'jpeg' })).src, Astro.site).href
  : '/og-image.png';

// Gallery items with high-res sources + captions (cover joins the same viewer group).
const galleryItems = await Promise.all(
  data.gallery
    .map((path) => ({ path, img: getGalleryImage(path) }))
    .filter((g) => g.img)
    .map(async (g) => ({
      img: g.img!,
      full: (await getImage({ src: g.img!, width: 2400, format: 'webp' })).src,
      caption: getCaption(g.path),
      alt: getCaption(g.path) || `${data.title} — field photo`,
    })),
);
---
<BaseLayout title={`${data.title} — ${data.siteType}`} description={data.summary} image={ogImage} ogType="article">
  <article class="detail">
    <div class="u-container">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Projects', href: 'projects/' }, { label: data.title }]} />

      <header class="detail__header" data-reveal>
        <StatusBadge status={data.status} />
        <h1 class="detail__title">{data.title}</h1>
        <dl class="detail__facts">
          <div><dt>Client / Site</dt><dd>{data.client}</dd></div>
          <div><dt>Type</dt><dd>{data.siteType}</dd></div>
          <div><dt>Role</dt><dd>{data.role}</dd></div>
          <div><dt>Dates</dt><dd class="u-mono">{dateRange(data.startDate, data.endDate)}</dd></div>
        </dl>
        <ul class="card__tags" style="margin-top:1.4rem;display:flex;flex-wrap:wrap;gap:0.4rem;list-style:none;padding:0;">
          {data.techniques.map((t) => <li class="chip">{t}</li>)}
        </ul>
        {data.envirostorQuery && (
          <div style="margin-top:1.8rem;max-width:42rem;">
            <LiveRegulatoryStatus query={data.envirostorQuery} client:visible />
          </div>
        )}
      </header>
    </div>

    {cover && (
      <div class="u-container">
        <button
          class="detail__cover-btn"
          data-lightbox
          data-figure
          data-gallery={group}
          data-full={coverFull}
          data-caption={coverCaption}
          aria-label="Open cover image"
        >
          <Image
            src={cover}
            alt={coverCaption || `${data.title} — ${data.siteType}`}
            widths={[600, 1000, 1600, 2000]}
            sizes="(max-width: 900px) 92vw, 80rem"
            class="detail__cover"
            style={`view-transition-name: cover-${project.id}`}
          />
        </button>
      </div>
    )}

    <div class="u-container detail__bodywrap">
      <div class="detail__body prose" data-reveal>
        <Content />
      </div>

      <aside class="detail__aside" data-reveal>
        <TableOfContents headings={headings} />
        {data.externalLink && (
          <a href={data.externalLink} class="btn btn--ghost" target="_blank" rel="noopener" data-magnetic="0.3">
            External reference ↗
          </a>
        )}
        <a href={withBase('#contact')} class="btn" data-magnetic="0.3">Discuss this work</a>
      </aside>
    </div>

    {galleryItems.length > 0 && (
      <div class="u-container">
        <h2 style="font-size:var(--text-xl);margin:3rem 0 1.5rem;">Field gallery</h2>
        <div class="gallery" data-reveal-stagger>
          {galleryItems.map((g) => (
            <button
              class="gallery__item"
              data-lightbox
              data-gallery={group}
              data-full={g.full}
              data-caption={g.caption}
              aria-label={`Open photo: ${g.alt}`}
            >
              <Image src={g.img} alt={g.alt} widths={[400, 800]} sizes="(max-width: 640px) 45vw, 18rem" loading="lazy" />
            </button>
          ))}
        </div>
      </div>
    )}
  </article>
</BaseLayout>

<script>
  import '../../lib/lightbox';
</script>

<script>
  // Scroll-spy for the case-study TOC (no progress bar here — that element
  // doesn't exist on project pages, so initProgress no-ops).
  import '../../lib/blogpost';
</script>

<style>
  .detail { padding-top: 7rem; }
  .detail__back { display: inline-block; color: var(--color-muted); font-size: var(--text-sm); margin-bottom: 2.5rem; }
  .detail__title { font-size: var(--text-3xl); margin: 1rem 0 2rem; max-width: 18ch; }
  .detail__facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: 1.4rem;
    border-top: 1px solid color-mix(in srgb, var(--color-paper) 12%, transparent);
    padding-top: 1.6rem;
    max-width: 56rem;
  }
  .detail__facts dt { color: var(--color-muted); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.12em; }
  .detail__facts dd { margin-top: 0.4rem; font-size: var(--text-base); }
  .detail__cover-btn { display: block; width: 100%; padding: 0; border: 0; background: none; cursor: zoom-in; }
  .detail__cover { width: 100%; height: auto; border-radius: 6px; margin: clamp(2rem, 6vw, 4rem) 0; aspect-ratio: 16 / 9; object-fit: cover; transition: transform 0.5s var(--ease-out-expo); border: 1px solid var(--color-line); }
  .detail__cover-btn:hover .detail__cover { transform: scale(1.01); }
  .detail__bodywrap { display: grid; grid-template-columns: 1fr; gap: 2.5rem; }
  @media (min-width: 900px) {
    .detail__bodywrap { grid-template-columns: minmax(0, 1fr) 18rem; align-items: start; }
  }
  .detail__aside { display: flex; flex-direction: column; gap: 0.9rem; position: sticky; top: 6rem; }
  .prose { max-width: 62ch; line-height: 1.75; color: var(--color-paper-soft); }
  .prose :global(h2) { font-size: var(--text-xl); margin: 2rem 0 1rem; color: var(--color-paper); }
  .prose :global(p) { margin-bottom: 1.1rem; }
  .prose :global(blockquote) {
    border-left: 2px solid var(--color-field-bright);
    padding: 0.6rem 1.2rem;
    margin: 1.5rem 0;
    color: var(--color-muted);
    font-size: var(--text-sm);
    background: color-mix(in srgb, var(--color-field-dim) 30%, transparent);
    border-radius: 0 8px 8px 0;
  }
  .prose :global(strong) { color: var(--color-paper); }
  .prose :global(a) { color: var(--color-field-bright); text-decoration: underline; }
</style>
