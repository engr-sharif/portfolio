---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/atlas/PageHeader.astro';
import About from '../../components/About.astro';
import SkillsMatrix from '../../components/SkillsMatrix.astro';
import Timeline from '../../components/Timeline.astro';
import Credentials from '../../components/Credentials.astro';
import { site } from '../../lib/site';
---
<BaseLayout
  title="About — Nawaz Sharif"
  description={site.bio}
>
  <main class="u-container">
    <PageHeader
      eyebrow="About"
      title="Environmental engineer, EIT"
      intro={site.bio}
      crumbs={[{ label: 'Home', href: '/' }, { label: 'About' }]}
    />
  </main>

  <SkillsMatrix />
  <Timeline />
  <Credentials />
  <About />
</BaseLayout>
