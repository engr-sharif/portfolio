---
import { render } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import TableOfContents from '../../components/blog/TableOfContents.astro';
import { getBlogImage } from '../../lib/images';
import { withBase } from '../../lib/path';
import { site } from '../../lib/site';
import { getPosts, getRelated, CATEGORY_LABEL, formatDate, tagSlug } from '../../lib/blog';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { data } = post;
const { Content, headings, remarkPluginFrontmatter } = await render(post);
const cover = getBlogImage(data.coverImage);
const related = await getRelated(post);
const minutesRead = remarkPluginFrontmatter.minutesRead as string | undefined;
// Per-post social share image: the cover, cropped to the OG ratio (absolute
// URL); falls back to the site default.
const ogImage = cover
  ? new URL((await getImage({ src: cover, width: 1200, height: 630, fit: 'cover', format: 'jpeg' })).src, Astro.site).href
  : '/og-image.png';

// JSON-LD Article structured data (absolute, base-aware URLs).
const url = new URL(withBase(`blog/${post.id}/`), Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: data.title,
  description: data.description,
  datePublished: data.pubDate.toISOString(),
  dateModified: (data.updatedDate ?? data.pubDate).toISOString(),
  author: { '@type': 'Person', name: site.name, url: Astro.site?.href },
  image: /^https?:\/\//.test(ogImage) ? ogImage : new URL(withBase(ogImage), Astro.site).href,
  mainEntityOfPage: url,
  keywords: data.tags.join(', '),
};
---
<BaseLayout title={`${data.title} — Nawaz Sharif`} description={data.description} image={ogImage} ogType="article">
  <div id="read-progress" aria-hidden="true"></div>

  <article class="post u-container" data-post-body>
    <a href={withBase('blog/')} class="link-underline" style="color:var(--color-muted);font-size:var(--text-sm);">← All writing</a>

    <header style="margin:2rem 0 2.5rem;max-width:60ch;" data-reveal>
      <div class="post-card__meta" style="margin-top:0;">
        {data.category && <span class="post-card__cat">{CATEGORY_LABEL[data.category]}</span>}
        <time datetime={data.pubDate.toISOString()}>{formatDate(data.pubDate)}</time>
        {minutesRead && <span>· {minutesRead}</span>}
      </div>
      <h1 style="font-size:var(--text-3xl);margin:1rem 0;">{data.title}</h1>
      <p style="color:var(--color-paper-soft);font-size:var(--text-lg);">{data.description}</p>
      {data.tags.length > 0 && (
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-top:1.2rem;">
          {data.tags.map((t) => <a class="tag-chip" href={withBase(`blog/tags/${tagSlug(t)}/`)}>{t}</a>)}
        </div>
      )}
    </header>

    {cover && (
      <Image
        src={cover}
        alt={data.coverAlt || data.title}
        widths={[600, 1000, 1600]}
        sizes="(max-width: 900px) 92vw, 70rem"
        style="width:100%;height:auto;border-radius:16px;margin-bottom:clamp(2rem,5vw,3.5rem);aspect-ratio:16/9;object-fit:cover;"
        data-reveal
      />
    )}

    <div class="post__layout">
      <TableOfContents headings={headings} />
      <div class="prose">
        <Content />
      </div>
    </div>

    {related.length > 0 && (
      <section style="margin-top:5rem;">
        <h2 style="font-size:var(--text-xl);margin-bottom:1.5rem;">Related writing</h2>
        <div class="blog-grid">
          {related.map((p) => <BlogCard post={p} />)}
        </div>
      </section>
    )}
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
</BaseLayout>

<script>
  import '../../lib/blogpost';
</script>
